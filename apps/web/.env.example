# Database — local: docker compose up -d (see README)
# postgresql://fnm:fnm_dev_password@localhost:5432/freelancenearme?schema=public
# Production: Neon Postgres
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Local dev: bypass Clerk and use seed users (client@ / talent@ demo emails)
DEV_AUTH_BYPASS=false
# DEV_AUTH_USER=client   # or talent when DEV_AUTH_BYPASS=true

# App URL (webhooks, emails, Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PLATFORM_FEE_PERCENT=10

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=Freelance Near Me <onboarding@resend.dev>

# Vercel Blob — https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
