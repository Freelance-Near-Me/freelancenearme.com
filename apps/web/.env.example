# =============================================================================
# Freelance Near Me — environment variables (apps/web)
# =============================================================================
# Copy to apps/web/.env for local dev:
#   cp apps/web/.env.example apps/web/.env
# Also copy DATABASE_URL to packages/database/.env (Prisma CLI).
# Quick start with DB + seed: npm run setup:dev
# =============================================================================

# -----------------------------------------------------------------------------
# Required — database
# -----------------------------------------------------------------------------
# Local (Docker): npm run dev:db  OR  docker compose up -d
# DATABASE_URL="postgresql://fnm:fnm_dev_password@localhost:5432/freelancenearme?schema=public"
# Prisma dev: use TCP URL from `npx prisma dev` (press t) — not the HTTP pooler URL
# Production (Neon): pooled connection string with ?sslmode=require
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# -----------------------------------------------------------------------------
# Required for production — app URL
# -----------------------------------------------------------------------------
# Used for Stripe redirects, emails, absolute links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Local dev only — auth without Clerk (never set in production)
# -----------------------------------------------------------------------------
DEV_AUTH_BYPASS=true
# DEV_AUTH_USER=client
# DEV_AUTH_USER=talent

# -----------------------------------------------------------------------------
# Clerk — https://dashboard.clerk.com
# Required in production (or keep DEV_AUTH_BYPASS=false with keys set)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Webhook: POST https://<domain>/api/webhooks/clerk
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# -----------------------------------------------------------------------------
# Stripe Connect — https://dashboard.stripe.com
# Optional locally; required for milestone checkout & payouts
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook: POST https://<domain>/api/webhooks/stripe
# Events: checkout.session.completed, account.updated
STRIPE_WEBHOOK_SECRET=

# Platform fee (server uses PLATFORM_FEE_PERCENT; UI uses NEXT_PUBLIC_*)
PLATFORM_FEE_PERCENT=10
NEXT_PUBLIC_PLATFORM_FEE_PERCENT=10

# -----------------------------------------------------------------------------
# Resend — https://resend.com
# Optional; emails log to console in development when unset
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Freelance Near Me <onboarding@resend.dev>"

# -----------------------------------------------------------------------------
# Vercel Blob — https://vercel.com/docs/storage/vercel-blob
# Optional; required for contract deliverable uploads
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=
