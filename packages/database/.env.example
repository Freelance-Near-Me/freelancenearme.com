# Prisma CLI — must match DATABASE_URL in apps/web/.env
#
#   cp apps/web/.env packages/database/.env
#   # or copy only DATABASE_URL from apps/web/.env
#
# Local Docker:
# DATABASE_URL="postgresql://fnm:fnm_dev_password@localhost:5432/freelancenearme?schema=public"

DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
