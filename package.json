{
  "name": "freelancenearme",
  "private": true,
  "version": "3.0.0",
  "description": "Freelance Near Me — Next.js marketplace on Vercel",
  "workspaces": [
    "apps/web",
    "packages/database",
    "server",
    "client"
  ],
  "scripts": {
    "postinstall": "npm run db:generate",
    "dev": "npm run dev -w web",
    "build": "npm run build -w web",
    "db:generate": "npm run db:generate -w @fnm/database",
    "db:push": "npm run db:push -w @fnm/database",
    "db:migrate": "npm run db:migrate -w @fnm/database",
    "db:seed": "npm run db:seed -w @fnm/database",
    "db:studio": "npm run db:studio -w @fnm/database",
    "legacy:dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "next": {
      "postcss": "^8.5.15"
    },
    "undici": "^6.24.0"
  }
}
